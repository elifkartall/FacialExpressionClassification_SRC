import numpy as np 
import os
import cv2
import pywt
import matplotlib.pyplot as plt
from sklearn.linear_model import Lasso

# ------------------------------------------------
# DATA PATH
# ------------------------------------------------
BASE_PATH = "/content/drive/MyDrive/Colab Notebooks/ML_HW1_EK/Part_C_images"
train_path = os.path.join(BASE_PATH,"train")
test_path = os.path.join(BASE_PATH,"test")
classes = ["disgusted_faces","happy_faces","sad_faces","surprised_faces"]

# ------------------------------------------------
# LOAD IMAGES
# ------------------------------------------------
def load_images(folder):
    images = []
    labels = []
    for label,cls in enumerate(classes):
        class_path = os.path.join(folder,cls)
        for file in os.listdir(class_path):
            img_path = os.path.join(class_path,file)
            img = cv2.imread(img_path,cv2.IMREAD_GRAYSCALE)
            img = cv2.resize(img,(48,48))
            images.append(img)
            labels.append(label)
    return np.array(images),np.array(labels)

# ------------------------------------------------
# IMAGE OPERATIONS
# ------------------------------------------------
def downsample(img):
    return img[::2,::2]

def flatten(img):
    return img.flatten()

def normalize_img(img):
    img = img - np.min(img)
    img = img / (np.max(img) + 1e-8)
    return img

# ------------------------------------------------
# FOURIER TRANSFORM
# ------------------------------------------------
def fourier_transform(img):
    f = np.fft.fft2(img)
    fshift = np.fft.fftshift(f)
    magnitude = np.log(1 + np.abs(fshift))
    return magnitude

# ------------------------------------------------
# WAVELET TRANSFORM
# ------------------------------------------------
def wavelet_transform(img):
    coeffs = pywt.dwt2(img,'haar')
    LL,(LH,HL,HH) = coeffs
    return LL

# ------------------------------------------------
# BUILD DATASET
# ------------------------------------------------
def build_dataset(transform=None):
    train_imgs,train_labels = load_images(train_path)
    test_imgs,test_labels = load_images(test_path)
    A=[]
    Y=[]
    processed_test_imgs=[]
    for img in train_imgs:
        img=downsample(img)
        if transform is not None:
            img=transform(img)
        A.append(flatten(img))
    for img in test_imgs:
        img=downsample(img)
        if transform is not None:
            img=transform(img)
        processed_test_imgs.append(img)
        Y.append(flatten(img))
    A=np.array(A).T
    Y=np.array(Y).T
    return A,train_labels,Y,test_labels,processed_test_imgs

# ------------------------------------------------
# SRC CLASSIFIER
# ------------------------------------------------
def SRC_analysis(A,y,train_labels):
    model=Lasso(alpha=0.001,max_iter=10000)
    model.fit(A,y)
    x=model.coef_
    residuals=[]
    for c in range(len(classes)):
        idx=np.where(train_labels==c)[0]
        delta=np.zeros_like(x)
        delta[idx]=x[idx]
        recon=A@delta
        r=np.linalg.norm(y-recon)
        residuals.append(r)
    predicted=np.argmin(residuals)
    return x,residuals,predicted

# ------------------------------------------------
# VISUALIZATION
# ------------------------------------------------
def plot_results(test_img,x,residuals,true_label,predicted_label,title):
    plt.figure(figsize=(16,5))
    # TEST IMAGE
    plt.subplot(1,3,1)
    img=normalize_img(test_img)
    plt.imshow(img,cmap="gray")
    plt.title(title + " Test Image")
    plt.axis("off")
    # SPARSE COEFFICIENTS
    plt.subplot(1,3,2)
    plt.stem(x)
    plt.title("Sparse Coefficients")
    plt.xlabel("Training Image Index")
    plt.ylabel("Coefficient")
    # RESIDUAL ERRORS
    plt.subplot(1,3,3)
    colors=["gray"]*len(classes)
    colors[predicted_label]="red"
    plt.bar(classes,residuals,color=colors)
    plt.title("Residual Errors")
    plt.ylabel("Reconstruction Error")
    plt.xticks(rotation=30)
    plt.show()
    print("True class:",classes[true_label])
    print("Predicted class:",classes[predicted_label])

# ------------------------------------------------
# BURADA TEST_INDEKS DEĞİŞTİRİLEBİLİR
# ------------------------------------------------
def run_domain_analysis(transform=None,domain_name="Original",test_index=1):
    A,train_labels,Y,test_labels,test_imgs=build_dataset(transform)

    # Tek bir test görseli için görselleştirme
    y=Y[:,test_index]
    test_img=test_imgs[test_index]
    x,residuals,pred=SRC_analysis(A,y,train_labels)
    plot_results(test_img,x,residuals,test_labels[test_index],pred,domain_name)

    # Tüm test seti için accuracy hesaplama
    correct = 0
    for i in range(Y.shape[1]):
        y_test = Y[:,i]
        x_test,res_test,pred_test = SRC_analysis(A,y_test,train_labels)
        if pred_test == test_labels[i]:
            correct += 1
    accuracy = correct / len(test_labels)
    print(f"\nOverall SRC Accuracy on test set ({domain_name}): {accuracy*100:.2f}%")


run_domain_analysis()  # Original images



run_domain_analysis(transform=fourier_transform, domain_name="Fourier")


run_domain_analysis(transform=wavelet_transform, domain_name="Wavelet")
